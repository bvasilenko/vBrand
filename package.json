{
  "name": "@booga/vbrand",
  "version": "0.1.2",
  "description": "Schema-driven Brand-OS CLI. Scaffold, emit assets, classify HTML, audit drift.",
  "type": "module",
  "bin": {
    "vbrand": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "template"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-template.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings 0",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@booga/vcli": "^0.1.3",
    "@booga/vssg": "^0.1.1",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "node-html-parser": "^6.1.13",
    "ora": "^7.0.1",
    "prompts": "^2.4.2",
    "sharp": "^0.33.0",
    "svgo": "^3.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
